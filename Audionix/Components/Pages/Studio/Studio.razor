@page "/studio"
@rendermode InteractiveServer

<PageTitle>Live Studio</PageTitle>

<MudPaper>
    <MudToolBar Dense="false" Variant="Variant.Outline">
        <MudPaper Class="mx-auto">
            <MudButton Class="ma-1" Variant="Variant.Outlined" OnClick="ToggleInsertDrawer">Insert</MudButton>
            <MudButton Class="ma-1" Variant="Variant.Outlined" OnClick="ToggleDelete">Delete</MudButton>
        </MudPaper>
    </MudToolBar>
</MudPaper>

<MudPaper >
    <MudDrawerContainer >
        <MudDrawer @bind-Open="@_open" Variant="DrawerVariant.Temporary" OverlayAutoClose="true" Width="400px" Anchor="Anchor.Right" Color="Color.Default">
            <MudPaper>
                <MudDrawerHeader>
                    <MudText Typo="Typo.h6">Add Audio</MudText>
                </MudDrawerHeader>

                <MudSelect Class="pl-1 pr-1" Margin="Margin.Dense" T="Folder" Label="Folders" Value="selectedFolder" Variant="Variant.Outlined" ValueChanged="OnFolderChanged">
                    @foreach (var folder in Folders)
                    {
                        <MudSelectItem Value="@folder">@folder.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudList T="string" Class="">
                    @foreach (var audioFile in AudioFiles)
                    {
                        <MudListItem Class="" @onclick="() => SelectAudioFile(audioFile)">
                            @audioFile.Title - @audioFile.Artist
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudDrawer>
    </MudDrawerContainer>

    <MudDataGrid Items="ProgramLog"
                 RowStyleFunc="@RowStyleFunc"
                 SortMode="SortMode.Single"
                 FixedHeader="true"
                 Virtualize="true"
                 ShowMenuIcon="false"
                 Dense="true"
                 Height="90vh">
        <Columns>
            <PropertyColumn Property="x => x.LogID" CellStyle="width: 5%;" SortBy="@(x => x.LogID)" />
            <PropertyColumn Property="x => x.Cue" CellStyle="width: 5%;" Sortable="false" />
            <PropertyColumn Property="x => x.Title" CellStyle="width: 15%;" Sortable="false" />
            <PropertyColumn Property="x => x.Artist" CellStyle="width: 15%;" Sortable="false" />
            <PropertyColumn Property="x => x.Name" CellStyle="width: 15%;" Sortable="false" />
            <PropertyColumn Property="x => x.Scheduled" CellStyle="width: 10%;" Sortable="false" />
            <PropertyColumn Property="x => x.Length" CellStyle="width: 10%;" Sortable="false" />
            <TemplateColumn CellStyle="width: 10%;" Sortable="false">
                <CellTemplate>
                    <MudProgressLinear Variant="Variant.Determinate" Color="Color.Success" Size="Size.Large" Value="50" />
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Segue" CellStyle="width: 10%;" Sortable="false" />
            <TemplateColumn CellStyle="width: 5%;" Sortable="false">
                <CellTemplate Context="cellContext">
                    <MudButton Variant="Variant.Outlined" Disabled="@(!IsAudioFileSelected)" OnClick="() => AddSelectedAudioToLog(cellContext.Item.LogID, cellContext.Item)">Add</MudButton>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn CellStyle="width: 5%;" Sortable="false">
                <CellTemplate Context="cellContext">
                    <MudButton Variant="Variant.Outlined" Disabled="@(!_delete)" OnClick="() => DeleteSelectedLogItem(cellContext.Item)">Delete</MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudPaper>
