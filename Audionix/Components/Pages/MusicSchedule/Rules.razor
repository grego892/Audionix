@page "/policies"
@inject ApplicationDbContext DbContext

<MudPaper Class="pa-2 ma-2">
    <MudTabs Border="true" Elevation="1">
        <MudTabPanel Text="Categories">
            <MudGrid Class="ma=2 pa-2">
                <MudItem xs="5">
                    <MudStack Row="true">
                        <MudTextField @bind-Value="newCategory" Label="New Category" Variant="Variant.Outlined" />
                        <MudButton OnClick="AddCategory" Color="Color.Primary" Variant="Variant.Filled">Add Category</MudButton>
                    </MudStack>
                </MudItem>
                <MudFlexBreak />
                <MudItem xs="6">
                    <MudTable Items="categories"
                              Bordered="true"
                              Dense="true"
                              Outlined="true">
                        <HeaderContent>
                            <MudTh>Category</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Category">@context</MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(args => RemoveCategoryHandler(@context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Sound Codes">
            <MudGrid Class="ma=2 pa-2">
                <MudItem xs="5">
                    <MudStack Row="true">
                        <MudTextField @bind-Value="newSoundCode" Label="New Sound Code" Variant="Variant.Outlined" />
                        <MudButton OnClick="AddSoundCode" Color="Color.Primary" Variant="Variant.Filled">Add Sound Code</MudButton>
                    </MudStack>
                </MudItem>
                <MudFlexBreak />
                <MudItem xs="6">
                    <MudTable Items="soundCodes"
                              Bordered="true"
                              Dense="true"
                              Outlined="true">
                        <HeaderContent>
                            <MudTh>Sound Code</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Sound Code">@context</MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(args => RemoveSoundCodeHandler(@context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Energy Levels">
            <MudGrid Class="ma=2 pa-2">
                <MudItem xs="5">
                    <MudStack Row="true">
                        <MudTextField @bind-Value="newEnergyLevel" Label="New Energy Level" Variant="Variant.Outlined" />
                        <MudButton OnClick="AddEnergyLevel" Color="Color.Primary" Variant="Variant.Filled">Add Energy Level</MudButton>
                    </MudStack>
                </MudItem>
                <MudFlexBreak />
                <MudItem xs="6">
                    <MudTable Items="energyLevels"
                              Bordered="true"
                              Dense="true"
                              Outlined="true">
                        <HeaderContent>
                            <MudTh>Energy Level</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Energy Level">@context</MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(args => RemoveEnergyLevelHandler(@context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="Music Schedule Settings">
            <MudGrid Class="ma=2 pa-2">
                <MudItem xs="5">
                    <MudNumericField Value="artistSeperation" Label="Autist Seperation" ValueChanged="UpdateSongScheduleSettings" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudPaper>

@code {

}
