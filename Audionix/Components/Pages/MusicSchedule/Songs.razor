<TemplateColumn>
    <HeaderTemplate>
        <MudText>Category</MudText>
    </HeaderTemplate>
    <CellTemplate>
        <MudSelect Margin="Margin.Dense" T="string" Label="Category" Value="selectedSongCategory" Variant="Variant.Outlined" ValueChanged="@(async (string value) => await UpdateCategory(value, context))">
            @foreach (var category in categories)
            {
                <MudSelectItem Value="@category.Name">@category.Name</MudSelectItem>
            }
        </MudSelect>
    </CellTemplate>
</TemplateColumn>

<TemplateColumn>
    <HeaderTemplate>
        <MudText>Sound Code</MudText>
    </HeaderTemplate>
    <CellTemplate>
        <MudSelect Margin="Margin.Dense" T="string" Label="Sound Code" Value="selectedSoundCode" Variant="Variant.Outlined" ValueChanged="@(async (string value) => await UpdateSoundCode(value, context))">
            @foreach (var soundCode in soundCodes)
            {
                <MudSelectItem Value="@soundCode.Code">@soundCode.Code</MudSelectItem>
            }
        </MudSelect>
    </CellTemplate>
</TemplateColumn>

<TemplateColumn>
    <HeaderTemplate>
        <MudText>Energy Level</MudText>
    </HeaderTemplate>
    <CellTemplate>
        <MudSelect Margin="Margin.Dense" T="string" Label="Energy Level" Value="selectedEnergyLevel" Variant="Variant.Outlined" ValueChanged="@(async (string value) => await UpdateEnergyLevel(value, context))">
            @foreach (var energyLevel in energyLevels)
            {
                <MudSelectItem Value="@energyLevel.Level">@energyLevel.Level</MudSelectItem>
            }
        </MudSelect>
    </CellTemplate>
</TemplateColumn>
