@using Audionix.Components.Pages
@using Audionix
@using SharedLibrary.Data
@using SharedLibrary.Models
@using Audionix.Repositories
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager
@inject AppStateService AppStateService
@inject IStationRepository StationRepository
@inject IJSRuntime JSRuntime

<AuthorizeView>
    <MudNavMenu>
        @if (AppStateService.AppSettings?.IsDatapathSetup == true && stations.Count > 0)
        {
            <MudSelect Class="pb-1 pa-2" Margin="Margin.Dense" T="Guid" Label="Station" Value="@(AppStateService.station?.StationId ?? Guid.Empty)" ValueChanged="OnStationChanged" Variant="Variant.Outlined" Placeholder="Select a station">
                @foreach (var station in stations)
                {
                    <MudSelectItem Value="@station.StationId">@(station.CallLetters ?? null)</MudSelectItem>
                }
            </MudSelect>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="/studio" Icon="@Icons.Material.Filled.Mic">Studio</MudNavLink>
            <MudNavLink Href="/filemanager" Icon="@Icons.Material.Filled.AudioFile">File Manager</MudNavLink>
            <MudNavLink Href="/logbuilder" Icon="@Icons.Material.Filled.ListAlt">Log Builder</MudNavLink>
            <MudNavGroup Title="Music Util" Expanded="false">
                <MudNavLink Href="/categories" Icon="@Icons.Material.Filled.Category">Categories</MudNavLink>
                <MudNavLink Href="/patterns" Icon="@Icons.Material.Filled.Pattern">Patterns</MudNavLink>
                <MudNavLink Href="/musicgrid" Icon="@Icons.Material.Filled.Grid4x4">Music Grid</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/audioedit" Icon="@Icons.Material.Filled.Edit">Audio Editor</MudNavLink>
            <MudNavLink Href="/setup" Icon="@Icons.Material.Filled.Settings">Setup</MudNavLink>
        }
        else
        {
            <MudNavLink Href="/setup" Icon="@Icons.Material.Filled.Settings">Initial Setup</MudNavLink>
        }
        <MudSpacer />
        <MudPaper Class="ma-1" Elevation="3">
            <MudField Label="Monitor Stream" Variant="Variant.Outlined">
                <MudSlider Value="@streamVolume" T="double" Min="0" Max="1" Step="0.05" ValueChanged="@(async (value) => await SetStreamVolume(value))" />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ToggleStreamStatus">@(streamStatus ? "Stop Stream" : "Start Stream")</MudButton>
                <MudField Class="pt-1" Label="Stream Status" Variant="Variant.Outlined" InnerPadding="false">
                    @streamStatusText
                </MudField>
            </MudField>
        </MudPaper>
    </MudNavMenu>
</AuthorizeView>


@code {
    private List<Station> stations = new();
    private bool streamStatus;
    private double streamVolume;
    private string streamStatusText = "Stopped";

    protected override async Task OnInitializedAsync()
    {
        AppStateService.OnAppSettingsChanged += HandleAppSettingsChanged;
        await AppStateService.LoadAppSettingsAsync();
        stations = await StationRepository.GetStationsAsync();
        if (stations.Any() && AppStateService.station == null)
        {
            AppStateService.station = stations.First();
        }
        AppStateService.OnStationChanged += HandleStationChanged;
    }

    private async Task OnStationChanged(Guid stationId)
    {
        AppStateService.station = stations.FirstOrDefault(s => s.StationId == stationId) ?? new Station();
        await Task.CompletedTask;
    }

    private void HandleStationChanged(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleAppSettingsChanged(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SetStreamVolume(double value)
    {
        streamVolume = value;
        await JSRuntime.InvokeVoidAsync("setVolume", value);
    }

    private async Task ToggleStreamStatus()
    {
        streamStatus = !streamStatus;
        streamStatusText = streamStatus ? "Playing" : "Stopped";
        if (streamStatus)
        {
            await JSRuntime.InvokeVoidAsync("playAudio");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("pauseAudio");
        }
    }

    public void Dispose()
    {
        AppStateService.OnStationChanged -= HandleStationChanged;
        AppStateService.OnAppSettingsChanged -= HandleAppSettingsChanged;
    }
}
