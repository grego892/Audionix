FROM nginx:alpine

   # Copy nginx configuration from project root/nginx directory
   COPY ./nginx/nginx.conf /etc/nginx/nginx.conf
   COPY ./nginx/default.conf /etc/nginx/conf.d/default.conf

   # We'll get static files from the frontend container
   # This requires a volume mount in docker-compose.yml

   EXPOSE 80

   CMD ["nginx", "-g", "daemon off;"]